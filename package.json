{
  "name": "learnbook",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "reader"
  ],
  "scripts": {
    "prepare": "husky",
    "dev": "npm run dev --workspace=reader",
    "build": "npm run build --workspace=reader",
    "test": "npm run test --workspace=reader",
    "lint": "npm run lint --workspace=reader",
    "lint:fix": "npm run lint:fix --workspace=reader",
    "format": "npm run format --workspace=reader",
    "format:check": "npm run format:check --workspace=reader",
    "db:seed": "npm run db:seed --workspace=reader",
    "db:reset": "npm run db:reset --workspace=reader"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1"
  },
  "lint-staged": {
    "reader/src/**/*.{ts,tsx}": [
      "eslint --config reader/eslint.config.mjs --fix",
      "prettier --write"
    ],
    "reader/src/**/*.css": [
      "prettier --write"
    ]
  }
}
